# Keep local-only and rebuildable artifacts out of the image.
.git
.github
/vendor
/node_modules
/tests

# Never ship local env or the dev SQLite database.
.env
.env.*
!.env.example
database/database.sqlite

# Transient storage (rebuilt at runtime).
storage/logs/*
storage/framework/cache/data/*
storage/framework/sessions/*
storage/framework/views/*
bootstrap/cache/*.php
